+                  {run.error ? <p className="mt-2 text-xs text-red-200">{run.error}</p> : null}
+                  <button
+                    type="button"
+                    className="mt-3 h-8 rounded-md border border-white/10 px-3 text-xs font-semibold text-white disabled:opacity-50"
+                    disabled={busy}
