#!/usr/bin/env bash
set -euo pipefail

url="${CODEX_FLEET_PLANE_FORK_URL:-https://github.com/makeplane/plane.git}"
ref="${CODEX_FLEET_PLANE_REF:-}"
target="${CODEX_FLEET_PLANE_DIR:-third_party/plane}"

mkdir -p "$(dirname "$target")"

if [ ! -d "$target/.git" ]; then
  git clone --filter=blob:none "$url" "$target"
fi

if [ -n "$ref" ]; then
  git -C "$target" fetch --depth 1 origin "$ref" || true
  git -C "$target" checkout "$ref"
fi

cat <<EOF
Plane source ready: $target
Remote: $url

Next:
  1. Replace CODEX_FLEET_PLANE_FORK_URL with the codex-fleet Plane fork URL.
  2. Pin CODEX_FLEET_PLANE_REF to the chosen commit.
  3. Add third_party/plane as a git submodule once the fork URL is stable.
  4. Add third_party/plane/AGENTS.md using docs/plane-fork.md guidance.
EOF
